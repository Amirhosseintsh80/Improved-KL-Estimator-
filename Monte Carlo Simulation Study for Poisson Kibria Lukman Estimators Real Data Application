    )
  )
  
  print(sub_table)
  cat("\n")
}

cat("\nSummary of Relative Efficiencies Averages across all variables:\n")
cat("-----------------------------------------------\n")

mean_re <- data.frame(
  Estimator = c("PKL", "PRKL", "PSKL", "PPSKL"),
  Mean_RE = c(
    mean(results_df$RE_PKL),
    mean(results_df$RE_PRKL),
    mean(results_df$RE_PSKL),
    mean(results_df$RE_PPSKL)
  ),
  Min_RE = c(
