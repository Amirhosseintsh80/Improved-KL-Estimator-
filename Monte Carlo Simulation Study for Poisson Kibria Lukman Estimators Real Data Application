library(ISLR)
library(car)
library(glmnet)
library(MASS)
library(dplyr)

data("Hitters")
df <- na.omit(Hitters)
vars <- c("AtBat", "Hits", "HmRun", "RBI", "Walks", 
          "CAtBat", "CHits", "CHmRun", "CRuns", "CRBI", "CWalks")

temp_model <- glm(as.formula(paste("Runs ~", paste(vars, collapse="+"))), 
                  family="poisson", data=df)
df_clean <- df[abs(rstandard(temp_model)) < 4, ]

# Goodness of Fit Test
final_model <- glm(as.formula(paste("Runs ~", paste(vars, collapse="+"))), 
                   family="poisson", data=df_clean)
p_value_gof <- pchisq(final_model$deviance, df.residual(final_model), lower.tail = FALSE)

cat(">>> 1. Goodness of Fit Test:\n")
cat("Remaining observations:", nrow(df_clean), "\n")
cat("P value:", format.pval(p_value_gof), "\n")
if(p_value_gof > 0.05) cat("Poisson model fit accepted\n") else cat("Fit is still poor\n")

# Multicollinearity Check
cat("\n>>> 2. Variance Inflation Factor values:\n")
print(vif(final_model))

