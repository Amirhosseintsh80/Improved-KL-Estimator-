    min(results_df$RE_PSKL),
    min(results_df$RE_PPSKL)
  ),
  Max_RE = c(
    max(results_df$RE_PKL),
    max(results_df$RE_PRKL),
    max(results_df$RE_PSKL),
    max(results_df$RE_PPSKL)
  )
)

